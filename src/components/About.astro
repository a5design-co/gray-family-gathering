<style>
  @keyframes reveal {
    from {
      opacity: 0;
      transform: scale(0.5);
      filter: blur(10px);
    }
    to {
      opacity: 1;
      transform: scale(1);
      filter: blur(0px);
    }
  }

  .reveal-video {
    @supports (animation-timeline: view()) {
      animation: reveal linear both;
      animation-timeline: view();
      animation-range: entry 10% cover 40%;
    }
  }

  .play-hint {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.15);
    transition: background 0.3s ease, opacity 0.3s ease;
    pointer-events: none;
  }

  .play-hint svg {
    width: 64px;
    height: 64px;
    opacity: 0.85;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.4));
    transition: transform 0.2s ease;
  }

  .video-wrapper:hover .play-hint {
    background: rgba(0, 0, 0, 0.25);
  }

  .video-wrapper:hover .play-hint svg {
    transform: scale(1.1);
  }

  /* hide the hint once the user has gone fullscreen */
  .video-wrapper.fullscreen-active .play-hint {
    opacity: 0;
  }
</style>

<section class="py-24 px-6 bg-gradient-to-b from-earth-cream to-white" id="about">
  <div class="max-w-4xl mx-auto space-y-12">
    <div class="text-center space-y-6">
      <h2 class="text-6xl text-earth-taupe font-serif">Join Us</h2>
      <p class="text-lg text-earth-taupe/80 leading-relaxed">
        Welcome to our family gathering! We are so excited to come together again, celebrate our roots, and create lasting memories. The video below is a wonderful glimpse back at our last gathering together for Thanksgiving—a beautiful reminder of the joy, laughter, and unbreakable bonds that tie us all together. Let's make this reunion just as unforgettable!
      </p>
    </div>

    <div class="relative rounded-2xl overflow-hidden shadow-2xl bg-earth-cream aspect-video reveal-video video-wrapper" id="about-video-wrapper">
      <video
        id="about-video"
        class="w-full h-full object-cover rounded-2xl cursor-pointer"
        loop
        muted
        playsinline
      >
        <source src="/about-video.mp4" type="video/mp4" />
      </video>

      <!-- Click-to-fullscreen hint overlay -->
      <div class="play-hint" aria-hidden="true">
        <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="32" cy="32" r="32" fill="white" fill-opacity="0.3"/>
          <polygon points="26,20 50,32 26,44" fill="white"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<script>
  const video = document.getElementById('about-video') as HTMLVideoElement;
  const wrapper = document.getElementById('about-video-wrapper') as HTMLElement;
  const iosVideo = video as HTMLVideoElement & {
    webkitEnterFullscreen?: () => void;
    webkitDisplayingFullscreen?: boolean;
    webkitRequestFullscreen?: () => void;
  };
  const webkitDocument = document as Document & {
    webkitFullscreenElement?: Element | null;
  };

  const isFullscreenActive = () =>
    Boolean(document.fullscreenElement || webkitDocument.webkitFullscreenElement || iosVideo.webkitDisplayingFullscreen);

  // 1. Autoplay muted when scrolled into view
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (isFullscreenActive()) return;

        if (entry.isIntersecting) {
          video.play().catch(() => {});
        } else {
          video.pause();
        }
      });
    },
    { threshold: 0.4 }
  );
  observer.observe(video);

  // 2. Tap/click -> fullscreen + unmute (desktop + Android + iOS Safari)
  const openVideoFullscreen = async () => {
    if (isFullscreenActive()) return;

    video.muted = false;
    await video.play().catch(() => {});

    try {
      if (typeof iosVideo.webkitEnterFullscreen === 'function') {
        iosVideo.webkitEnterFullscreen();
        wrapper.classList.add('fullscreen-active');
        return;
      }

      if (video.requestFullscreen) {
        await video.requestFullscreen();
        return;
      }

      if (typeof iosVideo.webkitRequestFullscreen === 'function') {
        iosVideo.webkitRequestFullscreen();
        return;
      }
    } catch (error) {
      console.error('Fullscreen request failed:', error);
    }
  };

  wrapper.addEventListener('click', openVideoFullscreen);

  // Re-mute when exiting fullscreen so ambient loop stays silent
  document.addEventListener('fullscreenchange', () => {
    if (!isFullscreenActive()) {
      video.muted = true;
      wrapper.classList.remove('fullscreen-active');
    } else {
      wrapper.classList.add('fullscreen-active');
    }
  });

  // iOS Safari fullscreen events
  video.addEventListener('webkitbeginfullscreen', () => {
    wrapper.classList.add('fullscreen-active');
  });

  video.addEventListener('webkitendfullscreen', () => {
    video.muted = true;
    wrapper.classList.remove('fullscreen-active');
  });
</script>
