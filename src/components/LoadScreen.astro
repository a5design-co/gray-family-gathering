---
---

<style>
  /* ── Overlay ── */
  #ls {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #F7F5F0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: clip;
    touch-action: none;
    /* Exit: whole overlay slides up, delayed so content fades first */
    transition: transform 1.15s cubic-bezier(0.76, 0, 0.24, 1) 0.32s;
  }
  #ls.exiting { transform: translateY(-100%); }

  #ls-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  /* ── Center copy ── */
  #ls-copy {
    position: relative;
    z-index: 3;
    text-align: center;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: opacity 0.28s ease;
  }
  #ls.exiting #ls-copy { opacity: 0; }

  .ls-eye {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: #C95B28;
    font-weight: 700;
    margin: 0 0 1rem;
    opacity: 0;
    transition: opacity 0.75s ease 0.3s;
  }

  .ls-title {
    font-family: 'Great Vibes', cursive;
    font-size: clamp(3.5rem, 12vw, 7.5rem);
    color: #3A6A32;
    line-height: 1.08;
    margin: 0 0 0.45rem;
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity  0.95s cubic-bezier(0.22, 1, 0.36, 1) 0.5s,
      transform 0.95s cubic-bezier(0.22, 1, 0.36, 1) 0.5s;
  }

  .ls-sub {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(58, 106, 50, 0.5);
    font-weight: 600;
    margin: 0 0 2.8rem;
    opacity: 0;
    transition: opacity 0.75s ease 0.88s;
  }

  /* Progress bar */
  .ls-track {
    width: 168px;
    height: 1px;
    background: rgba(58, 106, 50, 0.14);
    border-radius: 99px;
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.6s ease 1.1s;
  }
  .ls-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #C95B28 0%, #d4a853 100%);
    border-radius: 99px;
    transition: width 0.12s linear;
  }

  /* ── .ready reveals text ── */
  #ls.ready .ls-eye,
  #ls.ready .ls-sub,
  #ls.ready .ls-track  { opacity: 1; }
  #ls.ready .ls-title  { opacity: 1; transform: translateY(0); }

</style>

<div id="ls">
  <canvas id="ls-canvas"></canvas>

  <div id="ls-copy">
    <p class="ls-eye">You are cordially invited</p>
    <h1 class="ls-title">Gray Family</h1>
    <p class="ls-sub">Gathering &nbsp;·&nbsp; 2026</p>
    <div class="ls-track">
      <div class="ls-fill" id="ls-fill"></div>
    </div>
  </div>
</div>

<script is:inline>
(async () => {
const overlay = document.getElementById('ls');
const barFill = document.getElementById('ls-fill');
const canvas = document.getElementById('ls-canvas');

if (overlay) {
  const isMobileLike = window.matchMedia('(max-width: 900px), (pointer: coarse)').matches;
  const minDisplayMs = isMobileLike ? 1700 : 2000;
  const exitDelayMs = isMobileLike ? 450 : 3300;
  const exitAnimMs = 1500;

  let pct = 0;
  let fakeProgress = 0;
  let exitStartProgress = 0;
  let exitScheduledAt = 0;
  let exitScheduled = false;
  let exitTimer = null;
  let minDone = false;
  let readyDone = document.readyState === 'interactive' || document.readyState === 'complete';
  let exiting = false;
  let cleanupThree = () => {};

  function setBar(v) {
    pct = Math.max(pct, Math.min(100, v));
    if (barFill) barFill.style.width = `${pct}%`;
  }

  function cleanupOverlay() {
    cleanupThree();
    overlay.remove();
  }

  function triggerExit() {
    if (exiting) return;
    if (exitTimer) {
      window.clearTimeout(exitTimer);
      exitTimer = null;
    }
    window.clearInterval(fakeTimer);
    exiting = true;
    setBar(100);
    overlay.classList.add('exiting');
    window.setTimeout(cleanupOverlay, exitAnimMs);
  }

  function tryExit() {
    if (!minDone || !readyDone || exiting || exitScheduled) return;
    exitScheduled = true;
    exitScheduledAt = performance.now();
    exitStartProgress = Math.max(fakeProgress, 90);
    fakeProgress = exitStartProgress;
    setBar(fakeProgress);
    exitTimer = window.setTimeout(triggerExit, exitDelayMs);
  }

  window.requestAnimationFrame(() => overlay.classList.add('ready'));

  const fakeTimer = window.setInterval(() => {
    if (exiting) return;

    if (exitScheduled) {
      const elapsed = Math.max(0, performance.now() - exitScheduledAt);
      const phase = Math.min(1, elapsed / Math.max(1, exitDelayMs));
      const easedPhase = 1 - Math.pow(1 - phase, 2.1);
      const target = exitStartProgress + (99.2 - exitStartProgress) * easedPhase;
      const drift = (1 - phase) * (0.22 + Math.random() * 0.22);
      fakeProgress = Math.min(99.2, Math.max(fakeProgress + drift, target));
    } else {
      fakeProgress += 2 + Math.random() * 4;
      if (fakeProgress > 88) fakeProgress = 88 + (fakeProgress - 88) * 0.18;
      fakeProgress = Math.min(fakeProgress, 90);
    }

    setBar(fakeProgress);
  }, 150);

  // Keep the splash visible briefly, but do not block forever on slow mobile loads.
  window.setTimeout(() => {
    minDone = true;
    tryExit();
  }, minDisplayMs);

  const markReady = () => {
    readyDone = true;
    tryExit();
  };

  if (!readyDone) {
    document.addEventListener('DOMContentLoaded', markReady, { once: true });
    window.addEventListener('load', markReady, { once: true });
  }

  // Hard safety timeout so the overlay never gets stuck on mobile.
  window.setTimeout(() => {
    readyDone = true;
    minDone = true;
    tryExit();
  }, 8000);

  initThree()
    .then((cleanup) => { cleanupThree = cleanup; })
    .catch(() => {});

  async function initThree() {
    if (!canvas || exiting || !overlay.isConnected) return () => {};

    let THREE;
    try {
      THREE = await import('https://esm.sh/three@0.169.0');
    } catch {
      return () => {};
    }

    if (exiting || !overlay.isConnected) return () => {};

    function ease(t) {
      return t < 0.5 ? 2 * t * t : 1 - (-2 * t + 2) ** 2 / 2;
    }

    function pick(arr) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function oakPoint(i, n) {
      const trunkCount = Math.floor(n * 0.2);
      const branchCount = Math.floor(n * 0.16);
      const branchSet = [
        { az: -2.74, elev: 0.48, len: 2.05, baseY: -0.92 },
        { az: -2.18, elev: 0.55, len: 1.78, baseY: -0.82 },
        { az: -1.48, elev: 0.5, len: 1.72, baseY: -0.74 },
        { az: -0.64, elev: 0.56, len: 1.95, baseY: -0.86 },
        { az: 0.22, elev: 0.51, len: 2.15, baseY: -0.9 },
        { az: 0.86, elev: 0.54, len: 1.88, baseY: -0.78 },
        { az: 1.56, elev: 0.44, len: 1.66, baseY: -0.7 },
        { az: 2.24, elev: 0.58, len: 1.8, baseY: -0.82 },
      ];

      if (i < trunkCount) {
        const t = Math.pow(Math.random(), 0.88);
        const y = -2.48 + t * 1.86;
        const flare = t < 0.2 ? 1 + (0.2 - t) * 4.2 : 1;
        const radius = (0.24 - t * 0.11) * flare + Math.random() * 0.036;
        const ang = Math.random() * Math.PI * 2;
        const lean = Math.sin(t * 1.28) * 0.07;
        return {
          pos: new THREE.Vector3(
            Math.cos(ang) * radius + lean,
            y,
            Math.sin(ang) * radius * 0.9,
          ),
          kind: 'bark',
        };
      }

      if (i < trunkCount + branchCount) {
        const branch = pick(branchSet);
        const u = Math.pow(Math.random(), 0.72);
        const len = branch.len * (0.14 + u * 0.86);
        const az = branch.az + (Math.random() - 0.5) * 0.24;
        const elev = branch.elev + (Math.random() - 0.5) * 0.16;
        const thickness = (1 - u) * 0.14 + 0.02;
        const x = Math.cos(az) * len + (Math.random() - 0.5) * thickness;
        const y = branch.baseY + Math.sin(elev) * len + (Math.random() - 0.5) * thickness * 0.8;
        const z = Math.sin(az) * len * 0.92 + (Math.random() - 0.5) * thickness;
        return {
          pos: new THREE.Vector3(x, y, z),
          kind: 'bark',
        };
      }

      const h = Math.pow(Math.random(), 0.76);
      let y = -0.66 + h * 3.1;
      const profile = Math.sin(Math.min(0.999, h + 0.09) * Math.PI);
      const maxRadius = 2.3 * Math.pow(Math.max(0.04, profile), 0.57);
      const angle = Math.random() * Math.PI * 2;
      let radius = Math.sqrt(Math.random()) * maxRadius * (0.82 + Math.random() * 0.24);
      if (h < 0.22 && radius < 0.58) radius = 0.58 + Math.random() * 0.34;
      y += Math.exp(-((h - 0.84) ** 2) / 0.016) * 0.14;

      const ripple = 1 + 0.07 * Math.sin(angle * 3.1 + h * 10);
      return {
        pos: new THREE.Vector3(
          Math.cos(angle) * radius * ripple,
          y,
          Math.sin(angle) * radius * 0.9 * (1 + 0.05 * Math.cos(angle * 2.4 + h * 6)),
        ),
        kind: 'leaf',
      };
    }

    function makeDot() {
      const sz = 64;
      const c = document.createElement('canvas');
      c.width = c.height = sz;
      const ctx = c.getContext('2d');
      const m = sz / 2;
      const g = ctx.createRadialGradient(m, m, 0, m, m, m);
      g.addColorStop(0, 'rgba(255,255,255,1)');
      g.addColorStop(0.38, 'rgba(255,255,255,0.72)');
      g.addColorStop(0.78, 'rgba(255,255,255,0.08)');
      g.addColorStop(1, 'rgba(255,255,255,0)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, sz, sz);
      return new THREE.CanvasTexture(c);
    }

    let W = window.innerWidth;
    let H = window.innerHeight;
    let raf = null;
    let time = 0;
    let gather = 0;
    let exitFade = 0;

    let renderer;
    try {
      renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: false });
    } catch {
      return () => {};
    }

    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.setSize(W, H);
    renderer.setClearColor(0, 0);

    const scene = new THREE.Scene();
    const cam = new THREE.PerspectiveCamera(60, W / H, 0.1, 100);
    cam.position.set(0, 0.12, 5.85);

    const BARK_PALETTE = ['#2B1D15', '#3A271C', '#4A3425', '#5A4130'];
    const LEAF_PALETTE = ['#1F4A1D', '#2A5C24', '#35712B', '#4A8A39', '#5E9F3E', '#7AB749'];

    const TREE_SCALE = isMobileLike ? 1.16 : 1.2;
    const N = isMobileLike ? 1200 : 2100;
    const tgts = [];
    const orgs = [];
    const pdata = [];

    for (let i = 0; i < N; i++) {
      const target = oakPoint(i, N);
      tgts.push(target.pos.multiplyScalar(TREE_SCALE));
      orgs.push(new THREE.Vector3(
        (Math.random() - 0.5) * 11,
        (Math.random() - 0.5) * 9,
        (Math.random() - 0.5) * 6,
      ));
      pdata.push({
        phase: Math.random() * Math.PI * 2,
        freq: target.kind === 'leaf' ? 0.72 + Math.random() * 0.7 : 0.45 + Math.random() * 0.45,
        bamp: target.kind === 'leaf' ? 0.06 + Math.random() * 0.07 : 0.02 + Math.random() * 0.03,
        sx: (Math.random() - 0.5) * (target.kind === 'leaf' ? 0.32 : 0.12),
        sy: target.kind === 'leaf' ? 0.08 + Math.random() * 0.22 : 0.02 + Math.random() * 0.05,
        sz: (Math.random() - 0.5) * (target.kind === 'leaf' ? 0.32 : 0.12),
        driftPhase: Math.random() * Math.PI * 2,
        driftFreq: target.kind === 'leaf' ? 0.5 + Math.random() * 0.6 : 0.35 + Math.random() * 0.45,
        driftAmp: target.kind === 'leaf' ? 0.014 + Math.random() * 0.02 : 0.006 + Math.random() * 0.01,
        kind: target.kind,
      });
    }

    const pos = new Float32Array(N * 3);
    const cols = new Float32Array(N * 3);

    for (let i = 0; i < N; i++) {
      pos[i * 3] = orgs[i].x;
      pos[i * 3 + 1] = orgs[i].y;
      pos[i * 3 + 2] = orgs[i].z;
      let col;
      if (pdata[i].kind === 'bark') {
        col = new THREE.Color(BARK_PALETTE[Math.floor(Math.random() * BARK_PALETTE.length)]);
      } else {
        const base = new THREE.Color(LEAF_PALETTE[Math.floor(Math.random() * LEAF_PALETTE.length)]);
        const highlight = THREE.MathUtils.clamp((tgts[i].y + 0.3) / 3.2, 0, 1) * 0.16;
        col = base.offsetHSL(-0.01 + Math.random() * 0.02, 0, highlight);
      }
      cols[i * 3] = col.r;
      cols[i * 3 + 1] = col.g;
      cols[i * 3 + 2] = col.b;
    }

    const geom = new THREE.BufferGeometry();
    geom.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    geom.setAttribute('color', new THREE.BufferAttribute(cols, 3));

    const tex = makeDot();
    const mat = new THREE.PointsMaterial({
      size: isMobileLike ? 0.058 : 0.054,
      vertexColors: true,
      transparent: true,
      opacity: 0.88,
      sizeAttenuation: true,
      depthWrite: false,
      map: tex,
    });

    const pts = new THREE.Points(geom, mat);
    scene.add(pts);

    function onResize() {
      W = window.innerWidth;
      H = window.innerHeight;
      renderer.setSize(W, H);
      cam.aspect = W / H;
      cam.updateProjectionMatrix();
    }

    function stop() {
      if (raf) window.cancelAnimationFrame(raf);
      window.removeEventListener('resize', onResize);
      scene.remove(pts);
      renderer.dispose();
      tex.dispose();
      geom.dispose();
      mat.dispose();
    }

    function tick() {
      raf = window.requestAnimationFrame(tick);
      time += 0.008;

      if (!exiting) gather = Math.min(1, gather + 0.0105);
      const t = ease(gather);
      const pa = geom.attributes.position.array;

      for (let i = 0; i < N; i++) {
        const o = orgs[i];
        const tg = tgts[i];
        const d = pdata[i];
        const wave = (
          Math.sin(time * d.freq + d.phase) * 0.62 +
          Math.cos(time * d.freq * 1.73 + d.phase * 0.37) * 0.38
        ) * d.bamp * t;
        const driftT = time * d.driftFreq + d.driftPhase;
        const driftX = Math.sin(driftT) * d.driftAmp * t;
        const driftY = Math.sin(driftT * 1.18 + d.phase * 0.41) * d.driftAmp * 0.6 * t;
        const driftZ = Math.cos(driftT * 0.94 + d.phase * 0.2) * d.driftAmp * t;
        pa[i * 3] = o.x + (tg.x - o.x) * t + d.sx * wave + driftX;
        pa[i * 3 + 1] = o.y + (tg.y - o.y) * t + d.sy * wave + driftY;
        pa[i * 3 + 2] = o.z + (tg.z - o.z) * t + d.sz * wave + driftZ;
      }
      geom.attributes.position.needsUpdate = true;

      pts.rotation.y += 0.0009;
      if (pts.rotation.y > Math.PI * 2) pts.rotation.y -= Math.PI * 2;
      pts.rotation.x = -0.03 + Math.sin(time * 0.18) * 0.028;
      pts.position.y = Math.sin(time * 0.14) * 0.04 + Math.cos(time * 0.31) * 0.01;

      if (exiting) {
        exitFade = Math.min(1, exitFade + 0.0105);
        const fadeEase = ease(exitFade);
        pts.scale.setScalar(1 + fadeEase * 3.8);
        mat.opacity = Math.max(0, 0.88 - fadeEase * 0.75);
        if (!overlay.isConnected) {
          stop();
          return;
        }
      }

      renderer.render(scene, cam);
    }

    window.addEventListener('resize', onResize, { passive: true });
    tick();
    return stop;
  }
}
})().catch(() => {});
</script>
