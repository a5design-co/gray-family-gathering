<style>
    @supports (animation-timeline: scroll()) {
        @keyframes converge-tl {
            to { transform: translate3d(15rem, 15rem, 0) rotate(0deg) scale(0.5); opacity: 0; }
        }
        @keyframes converge-tr {
            to { transform: translate3d(-15rem, 15rem, 0) rotate(0deg) scale(0.5); opacity: 0; }
        }
        @keyframes converge-bl {
            to { transform: translate3d(15rem, -15rem, 0) rotate(0deg) scale(0.5); opacity: 0; }
        }
        @keyframes converge-br {
            to { transform: translate3d(-15rem, -15rem, 0) rotate(0deg) scale(0.5); opacity: 0; }
        }

        .img-tl {
            animation: converge-tl linear both;
            animation-timeline: scroll(root block);
            animation-range: 0 600px;
            will-change: transform, opacity;
        }
        .img-tr {
            animation: converge-tr linear both;
            animation-timeline: scroll(root block);
            animation-range: 0 600px;
            will-change: transform, opacity;
        }
        .img-bl {
            animation: converge-bl linear both;
            animation-timeline: scroll(root block);
            animation-range: 0 600px;
            will-change: transform, opacity;
        }
        .img-br {
            animation: converge-br linear both;
            animation-timeline: scroll(root block);
            animation-range: 0 600px;
            will-change: transform, opacity;
        }
    }
</style>

<section id="hero-section" class="relative min-h-screen bg-earth-cream flex flex-col items-center justify-center px-6 overflow-hidden">
