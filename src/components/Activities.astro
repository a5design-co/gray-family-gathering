---
export interface Activity {
  name:        string;
  sub:         string;
  url?:        string;
  photo?:      string;
  icon?:       string;
  comingSoon?: boolean;
}

export interface Props {
  activities?: Activity[];
  parkingNote?: string;
}

const {
  activities = [
    {
      name:  'Magnificent Mile',
      sub:   'World-class shopping & dining along Chicago\'s iconic stretch.',
      url:   'https://www.themagnificentmile.com',
      photo: 'https://www.themagnificentmile.com/hubfs/BarryButler-LakeshoreSunset-2.jpg',
    },
    {
      name:  'Navy Pier',
      sub:   'Lakefront entertainment, rides, and stunning city views.',
      url:   'https://navypier.org',
      photo: 'https://navypier.org/wp-content/uploads/2025/01/navy-pier-chicago-night-photo-from-drone.jpg',
    },
    {
      name:       'Taste of Chicago',
      sub:        'More information will be available closer to the event.',
      url:        'https://www.chicago.gov/city/en/depts/dca/supp_info/taste_of_chicago.html',
      photo:      'https://cdn.choosechicago.com/uploads/2019/08/CC_TasteOfChicago_Entrance_1e04704e-17c5-42fd-bb0b-15bc4cf583e2.jpg',
      comingSoon: false,
    },
    {
      name:  'Shedd Aquarium',
      sub:   'A family favorite on Chicago\'s Museum Campus lakefront.',
      url:   'https://www.sheddaquarium.org',
      photo: 'https://upload.wikimedia.org/wikipedia/commons/a/aa/20070110_Shedd_Aquarium.JPG',
    },
    {
      name:  'Museum of Science & Industry',
      sub:   'One of the largest science museums in the Western Hemisphere.',
      url:   'https://www.msichicago.org',
      photo: 'https://upload.wikimedia.org/wikipedia/commons/c/c4/MSIChicago.JPG',
    },
    {
      name:  'Chicago Architecture Tour',
      sub:   'See the city\'s iconic skyline from the Chicago River.',
      url:   'https://firstlady.com/cruises/architecture',
      photo: 'https://d2rcffbhqcoqge.cloudfront.?mtime=1759934543',
    },
    {
      name:  'Balloon Museum',
      sub:   'A colorful, immersive art experience unlike any other.',
      url:   'https://chicago.balloonmuseum.world',
      photo: 'https://media.timeout.com/images/106323523/image.jpg',
    },
    {
      name:  'Local Fitness',
      sub:   'Fitness Stairs & Trails · Lifetime Fitness · Planet Fitness',
      url:   'https://www.google.com/maps/search/local+fitness+chicago',
      photo: 'https://upload.wikimedia.org/wikipedia/commons/d/de/Interior_of_The_Gym_Group_showing_gym_equipment_and_signage%2C_Strood_Retail_Park%2C_Kent%2C_20_September_2025.jpg',
    },
  ],
  parkingNote = 'Reserve affordable parking across Chicago before you go.',
} = Astro.props;
---

<style>
  @keyframes activityFloat {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-2px); }
  }

  @keyframes cardSheen {
    0%, 70%, 100% { transform: translateX(-135%); }
    42%           { transform: translateX(135%); }
  }

  @keyframes imageBreath {
    0%, 100% { transform: scale(1.025); }
    50%      { transform: scale(1.045); }
  }

  .activity-card {
    position: relative;
    isolation: isolate;
    border: 1px solid rgba(58, 106, 50, 0.12);
    box-shadow:
      0 10px 24px rgba(58, 106, 50, 0.08),
      0 5px 12px rgba(201, 91, 40, 0.12);
    transition:
      transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.28s ease,
      border-color 0.28s ease;
    animation: activityFloat 7.2s ease-in-out infinite;
    will-change: transform;
  }

  .activity-card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      120deg,
      rgba(255, 255, 255, 0) 18%,
      rgba(255, 255, 255, 0.34) 46%,
      rgba(255, 255, 255, 0) 72%
    );
    transform: translateX(-135%);
    animation: cardSheen 10.5s ease-in-out infinite;
  }

  .activity-card:nth-child(2n) {
    animation-delay: 0.35s;
  }

  .activity-card:nth-child(3n) {
    animation-delay: 0.7s;
  }

  .activity-card:nth-child(2n)::after {
    animation-delay: 1.2s;
  }

  .activity-card:nth-child(3n)::after {
    animation-delay: 2.4s;
  }

  .activity-card:hover {
    transform: translateY(-6px) scale(1.012);
    border-color: rgba(201, 91, 40, 0.38);
    box-shadow:
      0 16px 32px rgba(58, 106, 50, 0.14),
      0 8px 20px rgba(201, 91, 40, 0.2);
  }

  .activity-card .card-img {
    animation: imageBreath 8.5s ease-in-out infinite;
    transition: transform 0.52s ease, filter 0.42s ease;
    transform-origin: center;
  }

  .activity-card:hover .card-img {
    animation-play-state: paused;
    transform: scale(1.075) translateY(-2px);
    filter: saturate(1.08);
  }

  .activity-card h3 {
    transition: color 0.22s ease;
  }

  .activity-card:hover h3 {
    color: #c95b28;
  }

  .visit-link {
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .visit-link .material-symbols-outlined {
    transition: transform 0.24s ease;
  }

  .activity-card:hover .visit-link {
    opacity: 0.9;
  }

  .activity-card:hover .visit-link .material-symbols-outlined {
    transform: translateX(3px);
  }

  .parking-tip {
    background:
      radial-gradient(circle at 10% 10%, rgba(201, 91, 40, 0.18), transparent 45%),
      linear-gradient(135deg, rgba(201, 91, 40, 0.12), rgba(58, 106, 50, 0.08));
    border: 2px solid rgba(201, 91, 40, 0.35);
    box-shadow: 0 18px 40px rgba(201, 91, 40, 0.22);
  }

  .parking-tip-badge {
    background: rgba(201, 91, 40, 0.12);
    border: 1px solid rgba(201, 91, 40, 0.35);
  }

  .parking-tip-cta {
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  }

  .parking-tip-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(201, 91, 40, 0.25);
  }

</style>

<section class="py-32 px-6 bg-earth-cream" id="activities">
  <div class="max-w-7xl mx-auto">
    <p class="text-xs uppercase tracking-[0.4em] text-primary/60 mb-2 font-bold">While You're in Town</p>
    <h2 class="text-4xl md:text-6xl font-serif italic text-earth-taupe mb-6">Things To Do in Chicago</h2>
    <div class="w-16 h-1 bg-primary mb-16"></div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {activities.map(a => (
        <div class="activity-card bg-white rounded-xl overflow-hidden flex flex-col">

          <!-- Photo or gradient fallback -->
          <div class="relative h-44 overflow-hidden">
            {a.photo ? (
              <img
                src={a.photo}
                alt={a.name}
                class="card-img w-full h-full object-cover"
                loading="lazy"
              />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-primary/15 to-earth-taupe/10 flex items-center justify-center">
                <span class="text-5xl" aria-hidden="true">{a.icon}</span>
              </div>
            )}

            {a.comingSoon && (
              <span class="absolute top-3 left-3 bg-primary text-white text-[10px] uppercase tracking-widest font-bold px-3 py-1 rounded-full shadow">
                Details Coming
              </span>
            )}
          </div>

          <!-- Card body -->
          <div class="p-5 flex flex-col flex-1">
            <h3 class="font-bold text-earth-taupe text-sm uppercase tracking-wider mb-2">{a.name}</h3>
            <p class="text-earth-taupe/60 text-sm leading-relaxed flex-1">{a.sub}</p>

            {a.url && (
              <a
                href={a.url}
                target="_blank"
                rel="noopener noreferrer"
                class="visit-link mt-4 inline-flex items-center text-primary text-xs font-bold uppercase tracking-widest"
                aria-label={`Learn more about ${a.name}`}
              >
                Learn More
                <span class="material-symbols-outlined" style="font-size:14px;line-height:1;margin-left:4px">arrow_forward</span>
              </a>
            )}
          </div>

        </div>
      ))}
    </div>

    <!-- Parking tip -->
    <div class="parking-tip mt-20 rounded-2xl overflow-hidden max-w-5xl mx-auto p-6 md:p-10 relative">
      <span class="parking-tip-badge inline-block rounded-full px-4 py-1 text-[10px] md:text-xs uppercase tracking-[0.2em] font-bold text-primary mb-5">
        Highly Recommended
      </span>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-5">
        <div class="w-14 h-14 md:w-16 md:h-16 rounded-full bg-primary text-white flex items-center justify-center shadow-lg shrink-0">
          <span class="material-symbols-outlined text-3xl">local_parking</span>
        </div>
        <div class="flex-1">
          <p class="text-primary font-bold tracking-widest text-xs uppercase mb-1">Parking Tip</p>
          <h3 class="text-2xl md:text-3xl font-serif text-earth-taupe mb-2">Reserve Parking Before You Arrive</h3>
          <p class="text-earth-taupe/80 text-base leading-relaxed mb-4">{parkingNote}</p>
          <a
            href="https://spothero.com"
            target="_blank"
            rel="noopener noreferrer"
            class="parking-tip-cta inline-flex items-center gap-2 bg-primary text-white border-2 border-primary px-6 py-3 rounded-full text-xs font-bold uppercase tracking-widest hover:bg-transparent hover:text-primary"
          >
            Reserve on SpotHero
            <span class="material-symbols-outlined" style="font-size:16px;line-height:1">arrow_forward</span>
          </a>
        </div>
      </div>
    </div>

  </div>
</section>
