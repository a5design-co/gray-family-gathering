---
export interface Props {
  action?:     string;
  netlify?:    boolean;
  formspreeId?: string; // e.g. "xpzgkbla" — set this if using Formspree instead
  googleScriptUrl?: string;
}

const {
  action     = '/thank-you',
  netlify    = true,
  formspreeId,
  googleScriptUrl = import.meta.env.PUBLIC_GOOGLE_SCRIPT_URL,
} = Astro.props;

const useGoogleScript = Boolean(googleScriptUrl);

// Form backend priority: Formspree > Google Apps Script > default action
const formAction = formspreeId
  ? `https://formspree.io/f/${formspreeId}`
  : useGoogleScript
    ? googleScriptUrl
    : action;
---

<canvas id="rsvp-confetti" style="display:none;position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:9999;"></canvas>

<section class="py-24 px-6 lg:px-12 bg-white dark:bg-background-dark" id="rsvp">
    <div class="max-w-6xl mx-auto">
        <div class="bg-white p-10 md:p-16 rounded-sm border-t-8 border-primary shadow-lg shadow-earth-taupe/5 relative overflow-hidden flex flex-col lg:flex-row gap-16 lg:gap-24">
            
            <!-- Background Icon -->
            <div class="absolute top-0 right-0 p-8 opacity-5 pointer-events-none">
                <span class="material-symbols-outlined text-9xl text-primary">mark_as_unread</span>
            </div>

            <!-- Left: info panel -->
            <div class="flex-1 relative z-10">
                <p class="text-xs uppercase tracking-[0.4em] text-primary font-bold mb-4">Don't Miss Out</p>
                <h2 class="text-6xl font-serif italic text-earth-taupe mb-6">RSVP NOW</h2>
                <div class="w-16 h-1 bg-primary mb-8"></div>
                
                <div class="text-earth-taupe/70 space-y-6 leading-relaxed text-lg">
                    <p>
                        We want to make sure we have a spot for every Gray! Fill out the form so we can plan food, space, and activities accordingly.
                    </p>
                    <p>
                        Remember to <strong class="text-earth-taupe">book your hotel room by June 15, 2026</strong> at the Hampton Inn by calling 
                        <a href="tel:7082988307" class="text-primary font-bold hover:underline">708-298-8307</a> and asking for the 
                        <em class="not-italic font-bold">Gray's Thanksgiving in July</em> group rate.
                    </p>
                    
                    <div class="mt-12 bg-earth-cream p-6 border-l-4 border-primary rounded-r-lg">
                        <span class="material-symbols-outlined text-primary mb-2">event_available</span>
                        <h4 class="font-bold text-earth-taupe uppercase tracking-widest text-xs mb-1">RSVP Deadline</h4>
                        <p class="text-earth-taupe/80">Please respond by <strong class="text-earth-taupe">June 15, 2026</strong>.</p>
                    </div>
                </div>
            </div>

            <!-- Right: form -->
            <div class="flex-[1.5] relative z-10">
                <form
                    id="rsvp-form"
                    name="rsvp"
                    method="POST"
                    action={formAction}
                    {...(netlify && !formspreeId && !useGoogleScript ? { 'data-netlify': 'true' } : {})}
                    {...(useGoogleScript ? {
                      'data-google-script': 'true',
                      'data-google-script-url': googleScriptUrl,
                    } : {})}
                    class="flex flex-col gap-6"
                >
                    {netlify && !formspreeId && !useGoogleScript && (
                        <input type="hidden" name="form-name" value="rsvp" />
                    )}

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-2">
                            <label for="name" class="text-[0.7rem] uppercase tracking-widest font-bold text-earth-taupe/60">Full Name *</label>
                            <input type="text" id="name" name="name" required placeholder="Your name" class="w-full bg-earth-cream border-transparent rounded-lg px-4 py-3 focus:ring-primary focus:border-primary transition-colors text-earth-taupe font-serif"/>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label for="guests" class="text-[0.7rem] uppercase tracking-widest font-bold text-earth-taupe/60">Number of Guests *</label>
                            <select id="guests" name="guests" required class="w-full bg-earth-cream border-transparent rounded-lg px-4 py-3 focus:ring-primary focus:border-primary transition-colors text-earth-taupe font-serif">
                                <option value="">Select…</option>
                                <option>Just me</option>
                                <option>2</option>
                                <option>3</option>
                                <option>4</option>
                                <option>5+</option>
                            </select>
                        </div>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label for="dietary" class="text-[0.7rem] uppercase tracking-widest font-bold text-earth-taupe/60">Dietary Restrictions / Allergies</label>
                        <input type="text" id="dietary" name="dietary" placeholder="e.g. vegetarian, nut allergy…" class="w-full bg-earth-cream border-transparent rounded-lg px-4 py-3 focus:ring-primary focus:border-primary transition-colors text-earth-taupe font-serif"/>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label for="friday" class="text-[0.7rem] uppercase tracking-widest font-bold text-earth-taupe/60">Friday Plans</label>
                        <select id="friday" name="friday" class="w-full bg-earth-cream border-transparent rounded-lg px-4 py-3 focus:ring-primary focus:border-primary transition-colors text-earth-taupe font-serif">
                            <option value="">Select your Friday preference</option>
                            <option>Fish Fry at the house</option>
                            <option>Taste of Chicago</option>
                            <option>Not sure yet</option>
                        </select>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label for="otherDish" class="text-[0.7rem] uppercase tracking-widest font-bold text-earth-taupe/60">Other Dish Contribution (optional)</label>
                        <input type="text" id="otherDish" name="otherDish" placeholder="Bringing something not listed? Tell us what dish you plan to bring." class="w-full bg-earth-cream border-transparent rounded-lg px-4 py-3 focus:ring-primary focus:border-primary transition-colors text-earth-taupe font-serif"/>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label for="message" class="text-[0.7rem] uppercase tracking-widest font-bold text-earth-taupe/60">Message for the Family (optional)</label>
                        <textarea id="message" name="message" rows="4" placeholder="Anything you'd like us to know or a shoutout to the fam!" class="w-full bg-earth-cream border-transparent rounded-lg px-4 py-3 focus:ring-primary focus:border-primary transition-colors text-earth-taupe font-serif"></textarea>
                    </div>

                    <button type="submit" class="mt-4 self-start bg-primary text-white border-2 border-primary px-10 py-4 rounded-full text-sm uppercase tracking-widest font-bold hover:bg-transparent hover:text-primary transition-all duration-300 shadow-lg hover:shadow-none">
                        Send My RSVP &rarr;
                    </button>
                    <p id="rsvp-status" class="hidden text-sm font-bold text-primary" aria-live="polite"></p>
                </form>
            </div>
            
        </div>
    </div>
</section>

<script is:inline type="module">
  import * as THREE from 'https://esm.sh/three@0.169.0';

  const canvas = document.getElementById('rsvp-confetti');
  if (!canvas) throw new Error('no confetti canvas');

  const COLORS = [
    0x63863f, // primary green
    0xa3c178, // light green
    0xfdfbf7, // cream
    0xc8a96e, // gold
    0xe8c84a, // bright gold
    0xd4a853, // amber
    0x4a4435, // dark taupe
    0xf0e8d0, // warm white
  ];

  let W = window.innerWidth;
  let H = window.innerHeight;
  let particles = [];
  let animId = null;

  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: false });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(W, H);
  renderer.setClearColor(0x000000, 0);

  const scene = new THREE.Scene();
  const camera = new THREE.OrthographicCamera(-W/2, W/2, H/2, -H/2, 0.1, 100);
  camera.position.z = 10;

  function domToThree(domX, domY) {
    return { x: domX - W / 2, y: -(domY - H / 2) };
  }

  function spawnParticle(ox, oy) {
    const color = COLORS[Math.floor(Math.random() * COLORS.length)];
    const w = 5 + Math.random() * 9;
    const h = 8 + Math.random() * 12;
    const geo = new THREE.PlaneGeometry(w, h);
    const mat = new THREE.MeshBasicMaterial({ color, side: THREE.DoubleSide, transparent: true });
    const mesh = new THREE.Mesh(geo, mat);
    mesh.position.set(ox, oy, Math.random() * 5);
    mesh.rotation.z = Math.random() * Math.PI * 2;
    scene.add(mesh);

    // Emit in a wide upward arc (~240°, biased away from straight down)
    const angle = -Math.PI / 2 + (Math.random() - 0.5) * Math.PI * 1.4;
    const speed = 4 + Math.random() * 16;

    return {
      mesh,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      vrx: (Math.random() - 0.5) * 0.25,
      vrz: (Math.random() - 0.5) * 0.18,
      gravity: 0.25 + Math.random() * 0.15,
      opacity: 1,
      life: 0,
      fadeStart: 55 + Math.random() * 35,
    };
  }

  function burst(btnX, btnY) {
    const { x: ox, y: oy } = domToThree(btnX, btnY);
    for (let i = 0; i < 190; i++) {
      particles.push(spawnParticle(ox, oy));
    }
  }

  function tick() {
    animId = requestAnimationFrame(tick);
    let alive = false;

    for (const p of particles) {
      p.life++;
      p.mesh.position.x += p.vx;
      p.mesh.position.y += p.vy;
      p.vy -= p.gravity;
      p.vx *= 0.995;
      p.mesh.rotation.x += p.vrx;
      p.mesh.rotation.z += p.vrz;

      if (p.life > p.fadeStart) {
        p.opacity -= 0.018;
        p.mesh.material.opacity = Math.max(0, p.opacity);
      }
      if (p.opacity > 0) alive = true;
    }

    renderer.render(scene, camera);

    if (!alive) {
      cancelAnimationFrame(animId);
      canvas.style.display = 'none';
      for (const p of particles) {
        scene.remove(p.mesh);
        p.mesh.geometry.dispose();
        p.mesh.material.dispose();
      }
      particles = [];
    }
  }

  window.addEventListener('resize', () => {
    W = window.innerWidth;
    H = window.innerHeight;
    renderer.setSize(W, H);
    camera.left   = -W / 2;
    camera.right  =  W / 2;
    camera.top    =  H / 2;
    camera.bottom = -H / 2;
    camera.updateProjectionMatrix();
  });

  const form = document.getElementById('rsvp-form');
  const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

  if (form) {
    const isGoogleSubmit = form.dataset.googleScript === 'true';
    const googleScriptUrl = form.dataset.googleScriptUrl;
    const status = document.getElementById('rsvp-status');
    const btn = form.querySelector('[type="submit"]');
    const originalBtnText = btn?.textContent || 'Send My RSVP →';
    let isSubmitting = false;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (isSubmitting) return;
      isSubmitting = true;

      if (status) {
        status.textContent = '';
        status.classList.add('hidden');
      }

      if (btn) {
        btn.disabled = true;
        btn.textContent = 'Sending...';
        btn.classList.add('opacity-70', 'cursor-not-allowed');
      }

      canvas.style.display = 'block';

      const rect = btn
        ? btn.getBoundingClientRect()
        : { left: W / 2, top: H / 2, width: 0, height: 0 };

      burst(rect.left + rect.width / 2, rect.top + rect.height / 2);
      tick();

      // Let confetti peak first so the feedback is visible.
      await wait(900);

      try {
        if (isGoogleSubmit && googleScriptUrl) {
          const formData = new FormData(form);
          await fetch(googleScriptUrl, {
            method: 'POST',
            body: formData,
            mode: 'no-cors',
          });

          await wait(500);
          window.location.href = '/thank-you';
          return;
        }

        await wait(900);
        form.submit();
      } catch (error) {
        console.error('RSVP submission failed:', error);

        if (status) {
          status.textContent = 'There was a problem sending your RSVP. Please try again.';
          status.classList.remove('hidden');
        }

        if (btn) {
          btn.disabled = false;
          btn.textContent = originalBtnText;
          btn.classList.remove('opacity-70', 'cursor-not-allowed');
        }

        isSubmitting = false;
      }
    });
  }
</script>
