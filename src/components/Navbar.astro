---

<nav class="w-full bg-earth-cream/80 backdrop-blur-lg sticky top-0 z-50 border-b border-earth-taupe/10 transition-all duration-300" id="navbar">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-50 bg-earth-cream/80 backdrop-blur-lg md:bg-transparent">

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center justify-between py-4">
            <!-- Left Links -->
            <div class="flex items-center gap-6 text-xs font-bold tracking-[0.2em] uppercase text-earth-taupe/70 w-1/3 justify-start">
                <a class="hover:text-primary transition-colors hover:underline underline-offset-4" href="#details">Details</a>
                <a class="hover:text-primary transition-colors hover:underline underline-offset-4" href="#story">Schedule</a>
                <a class="hover:text-primary transition-colors hover:underline underline-offset-4" href="#hotel">Hotel</a>
            </div>

            <!-- Logo -->
            <div class="flex items-center justify-center w-1/3">
                <a href="#" class="hover:opacity-80 transition-opacity text-center">
                    <span class="font-cursive text-4xl text-primary tracking-wide">Gray Gathering</span>
                </a>
            </div>

            <!-- Right Links -->
            <div class="flex items-center gap-6 text-xs font-bold tracking-[0.2em] uppercase text-earth-taupe/70 w-1/3 justify-end">
                <a class="hover:text-primary transition-colors hover:underline underline-offset-4" href="#activities">Activities</a>
                <a class="hover:text-primary transition-colors hover:underline underline-offset-4" href="#menu">Menu</a>
                <a class="hover:text-primary transition-colors hover:underline underline-offset-4" href="#rsvp">RSVP</a>
            </div>
        </div>

        <!-- Mobile Nav Bar -->
        <div class="flex md:hidden items-center justify-between py-4 h-16">
            <button id="mobile-menu-btn" class="text-earth-taupe focus:outline-none p-2 -ml-2" aria-label="Toggle menu">
                <span id="hamburger-icon" class="material-symbols-outlined text-3xl">menu</span>
            </button>

            <a href="#" class="font-cursive text-3xl text-primary tracking-wide">Gray Gathering</a>

            <a href="#rsvp" id="nav-rsvp-btn" class="bg-primary text-white px-4 py-2 rounded-full text-xs font-bold font-sans tracking-widest uppercase hover:bg-primary/90 transition-colors shadow-sm">
                RSVP
            </a>
        </div>
    </div>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="fixed inset-0 bg-earth-cream z-40 flex flex-col justify-center items-center gap-10 transition-transform duration-500 ease-in-out -translate-y-full md:hidden" style="height: 100dvh;">
        <a class="mobile-link text-base font-bold tracking-[0.2em] uppercase text-earth-taupe hover:text-primary transition-colors" href="#details">Details</a>
        <a class="mobile-link text-base font-bold tracking-[0.2em] uppercase text-earth-taupe hover:text-primary transition-colors" href="#story">Schedule</a>
        <a class="mobile-link text-base font-bold tracking-[0.2em] uppercase text-earth-taupe hover:text-primary transition-colors" href="#hotel">Hotel</a>
        <a class="mobile-link text-base font-bold tracking-[0.2em] uppercase text-earth-taupe hover:text-primary transition-colors" href="#activities">Activities</a>
        <a class="mobile-link text-base font-bold tracking-[0.2em] uppercase text-earth-taupe hover:text-primary transition-colors" href="#menu">Menu</a>
        <a class="mobile-link bg-primary text-white px-10 py-4 rounded-full text-base font-bold tracking-widest uppercase hover:bg-primary/90 transition-colors shadow-md" href="#rsvp">RSVP</a>
    </div>
</nav>

<script>
    const menuBtn = document.getElementById('mobile-menu-btn');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const mobileMenu = document.getElementById('mobile-menu');
    const navRsvpBtn = document.getElementById('nav-rsvp-btn');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    let isOpen = false;

    function openMenu() {
        isOpen = true;
        if (mobileMenu) mobileMenu.style.transform = 'translateY(0)';
        if (hamburgerIcon) hamburgerIcon.textContent = 'close';
        if (navRsvpBtn) navRsvpBtn.style.visibility = 'hidden';
        document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
        isOpen = false;
        if (mobileMenu) mobileMenu.style.transform = 'translateY(-100%)';
        if (hamburgerIcon) hamburgerIcon.textContent = 'menu';
        if (navRsvpBtn) navRsvpBtn.style.visibility = 'visible';
        document.body.style.overflow = '';
    }

    menuBtn?.addEventListener('click', () => isOpen ? closeMenu() : openMenu());

    mobileLinks.forEach(link => {
        link.addEventListener('click', closeMenu);
    });
</script>
