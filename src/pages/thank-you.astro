---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You | Gray Family Gathering 2026">
  <main class="min-h-screen px-6 py-24 flex items-center justify-center">
    <section class="max-w-2xl w-full bg-white p-10 md:p-14 border-t-8 border-primary shadow-lg shadow-earth-taupe/5 text-center">
      <p class="text-xs uppercase tracking-[0.35em] text-primary font-bold mb-4">RSVP Received</p>
      <h1 class="text-5xl font-serif italic text-earth-taupe mb-5">Thank You!</h1>
      <p class="text-earth-taupe/75 text-lg leading-relaxed mb-10">
        Your RSVP has been submitted. We appreciate you helping us plan the Gray Family Gathering.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="w-full sm:w-auto bg-primary text-white border-2 border-primary px-8 py-3 rounded-full text-xs uppercase tracking-widest font-bold hover:bg-transparent hover:text-primary transition-all duration-300"
        >
          Back to Event
        </a>
        <a
          href="/#rsvp"
          class="w-full sm:w-auto bg-white text-primary border-2 border-primary px-8 py-3 rounded-full text-xs uppercase tracking-widest font-bold hover:bg-primary hover:text-white transition-all duration-300"
        >
          Submit Another
        </a>
      </div>
    </section>
  </main>
</Layout>
